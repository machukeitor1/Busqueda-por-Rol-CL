<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F8FAFD"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A3A5C"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tvRol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#333333"
        android:fontFamily="monospace"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tvDestino"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvAvaluo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#1A6B3C"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="0dp">

        <Button
            android:id="@+id/btnItemCertificado"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="📄 TGR"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A3A5C"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnItemCertificadoSii"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="🏠 SII"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A6B3C"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Separador -->
    <View
        android:id="@+id/separador"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E8F0"
        android:layout_marginTop="14dp"/>

</LinearLayout>
