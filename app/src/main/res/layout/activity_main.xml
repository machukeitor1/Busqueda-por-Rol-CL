<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1A3A5C">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_logo"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Búsqueda por Rol"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Búsqueda de Rol por Dirección"
                    android:textSize="13sp"
                    android:textColor="#B0C8E8"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Widget Clima -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardClima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#0D2B47">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvClimaIcono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌡"
                    android:textSize="26sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvClimaTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvClimaDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="12sp"
                    android:textColor="#B0C8E8"
                    android:layout_marginEnd="6dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#2A4A6C"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvClimaDetalle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#7A9BBF"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Historial de búsquedas -->
        <HorizontalScrollView
            android:id="@+id/scrollHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/containerHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>

        </HorizontalScrollView>

        <!-- Formulario -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Label Región -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗺 REGIÓN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A5C"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <!-- Spinner Región -->
                <Spinner
                    android:id="@+id/spinnerRegion"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp"/>

                <!-- Label Comuna -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏙 COMUNA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A5C"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <!-- Spinner -->
                <Spinner
                    android:id="@+id/spinnerComuna"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp"/>

                <!-- Label Calle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛣 NOMBRE DE CALLE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A5C"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <!-- EditText Calle -->
                <EditText
                    android:id="@+id/etCalle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Ej: Constitución"
                    android:textSize="15sp"
                    android:inputType="textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp"
                    android:imeOptions="actionNext"/>

                <!-- Label Número -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔢 NÚMERO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A5C"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <!-- EditText Número -->
                <EditText
                    android:id="@+id/etNumero"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Ej: 756"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="24dp"
                    android:imeOptions="actionSearch"/>

                <!-- Botón Buscar -->
                <Button
                    android:id="@+id/btnBuscar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="BUSCAR ROL"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E85D04"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            android:indeterminateTint="#E85D04"/>

        <!-- Card Resultado -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 RESULTADO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A5C"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <!-- Mensaje vacío / error -->
                <TextView
                    android:id="@+id/tvResultado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:lineSpacingMultiplier="1.5"
                    android:visibility="gone"/>

                <!-- Contenedor dinámico: una tarjeta por resultado -->
                <LinearLayout
                    android:id="@+id/containerResultados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Creado por Cristian Machuca · Versión App 1.4"
            android:textSize="11sp"
            android:textColor="#8A9BB0"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
